{
  "printWidth": 120,
  "trailingComma": "all",
  "overrides": [
    {
      "files": [
        ".vscode/extensions.json",
        ".vscode/launch.json",
        ".vscode/tasks.json",
        "**/tsconfig.json",
        "**/tsconfig.*.json"
      ],
      "options": {
        "parser": "jsonc"
      }
    }
  ]
}
